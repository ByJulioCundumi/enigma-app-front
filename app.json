{
  "expo": {
    "name": "Enigma: Guess the Word",
    "slug": "enigma-app",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/images/appIcon.jpg",
    "scheme": "enigmaapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.enigma.guesstheword",
      "versionCode": 5,
      "adaptiveIcon": {},
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/appIcon.jpg"
    },
    "plugins": [
      "expo-router",
      "expo-iap",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo4.jpg",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4432010611800941~4288560604"
        }
      ],
      "expo-audio"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c7685301-acb9-40bd-8563-649a2b51e97e"
      }
    },
    "owner": "julio.dev"
  }
}
